# Polymarket Neg-Risk Bot - Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# === Required for execution mode (--execute) ===
# Wallet private key (0x-prefixed, 64 hex chars)
POLYMARKET_PRIVATE_KEY=0x...
# Wallet address (funder address for order placement)
POLYMARKET_FUNDER=0x...

# === Optional: Alert notifications ===
# Discord webhook URL (from Server Settings > Integrations > Webhooks)
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=12345678
